{
  "name": "project-janatha",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=@janatha/backend\" \"npm run dev --workspace=@janatha/frontend\"",
    "dev:frontend": "npm run dev --workspace=@janatha/frontend",
    "typecheck": "npm run typecheck --workspace=@janatha/backend",
    "build": "npm run typecheck && npm run build --workspace=@janatha/frontend && npm run build:pages",
    "build:frontend": "npm run build --workspace=@janatha/frontend",
    "build:pages": "cp -r packages/frontend/dist dist",
    "deploy": "npm run build && npx wrangler pages deploy dist",
    "deploy:preview": "npm run build && npx wrangler pages deploy dist --branch preview",
    "d1:create": "npx wrangler d1 create chinmaya-janata-db",
    "d1:create:preview": "npx wrangler d1 create chinmaya-janata-db-preview",
    "d1:migrate": "npx wrangler d1 execute chinmaya-janata-db --file=migrations/0001_initial_schema.sql",
    "d1:migrate:local": "npx wrangler d1 execute chinmaya-janata-db --local --file=migrations/0001_initial_schema.sql",
    "d1:migrate:preview": "npx wrangler d1 execute chinmaya-janata-db-preview --file=migrations/0001_initial_schema.sql",
    "pages:dev": "npm run build:frontend && npx wrangler pages dev dist",
    "android": "expo run:android",
    "ios": "expo run:ios"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260101.0",
    "concurrently": "^8.2.2",
    "wrangler": "^4.0.0"
  },
  "dependencies": {
    "hono": "^4.7.0",
    "jose": "^6.0.0"
  },
  "overrides": {
    "react": "19.2.4",
    "react-dom": "19.2.4"
  }
}

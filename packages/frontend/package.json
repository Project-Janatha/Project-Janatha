    "build": "npx expo export --platform web",
    "postinstall": "node -e \"const fs=require('fs'); const p='../../node_modules/react-native-css-interop/dist/css-to-rn/parseDeclaration.js'; const c=fs.readFileSync(p,'utf8'); if(!c.includes('!aspectRatio.ratio')){fs.writeFileSync(p,c.replace('function parseAspectRatio(aspectRatio) {\\n    if (aspectRatio.auto) {\\n        return \\\"auto\\\";\\n    }\\n    else {','function parseAspectRatio(aspectRatio) {\\n    if (aspectRatio.auto) {\\n        return \\\"auto\\\";\\n    }\\n    else if (!aspectRatio.ratio || !Array.isArray(aspectRatio.ratio)) {\\n        return \\\"auto\\\";\\n    }\\n    else {'))}\""
  },

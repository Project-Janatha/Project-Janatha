# Frontend (Expo) — copy to `.env` and set values. EXPO_PUBLIC_* is inlined at build time.

# PostHog project API key (PostHog → Project → API keys; starts with phc_)
EXPO_PUBLIC_POSTHOG_KEY=

# Optional; default in app is https://us.i.posthog.com
# EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

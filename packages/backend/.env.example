# Environment Configuration for Project Janatha Backend (Cloudflare Worker + D1)

# For local Worker testing only. In production, set secrets via Wrangler:
# npx wrangler secret put JWT_SECRET
# npx wrangler secret put JWT_REFRESH_SECRET

JWT_SECRET=your-super-secret-jwt-token-change-this-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-token-change-this-in-production

# Optional app-level defaults
ADMIN_NAME=brahman
